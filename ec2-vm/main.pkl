amends "@formae/forma.pkl"

import "@formae/formae.pkl"
import "@aws/ec2/securitygroup.pkl" as sg
import "@aws/ec2/securitygroupingress.pkl" as sgi
import "@aws/ec2/instance.pkl" as ec2
import "@aws/ec2/eip.pkl" as eip
import "@aws/ec2/eipassociation.pkl" as eipassoc

import "vars.pkl"

description {
    text = """
        Deploy an EC2 virtual machine with:
          - Security group (SSH + HTTP/HTTPS ingress, all egress)
          - Amazon Linux 2023 instance with basic user-data bootstrap
          - Elastic IP for a stable public address
        """
    confirm = true
}

local securityGroup = new sg.SecurityGroup {
    label = "vm-sg"
    groupName = "\(vars.projectName)-sg"
    groupDescription = "Security group for \(vars.projectName)"
    tags = new {
        new { key = "Name"; value = "\(vars.projectName)-sg" }
        new { key = "Project"; value = vars.projectName }
        new { key = "ManagedBy"; value = "formae" }
    }
}

local sshIngress = new sgi.SecurityGroupIngress {
    label = "ssh-ingress"
    groupId = securityGroup.res.groupId
    ipProtocol = "tcp"
    fromPort = 22
    toPort = 22
    cidrIp = "0.0.0.0/0"
    description = "SSH access"
}

local httpIngress = new sgi.SecurityGroupIngress {
    label = "http-ingress"
    groupId = securityGroup.res.groupId
    ipProtocol = "tcp"
    fromPort = 80
    toPort = 80
    cidrIp = "0.0.0.0/0"
    description = "HTTP access"
}

local httpsIngress = new sgi.SecurityGroupIngress {
    label = "https-ingress"
    groupId = securityGroup.res.groupId
    ipProtocol = "tcp"
    fromPort = 443
    toPort = 443
    cidrIp = "0.0.0.0/0"
    description = "HTTPS access"
}

local instance = new ec2.Instance {
    label = "vm"
    imageId = vars.amiId
    instanceType = vars.instanceType
    keyName = vars.keyName
    securityGroupIds { securityGroup.res.groupId }
    userData = """
        #!/bin/bash
        yum update -y
        yum install -y git curl wget unzip
        echo "VM ready: \(vars.projectName)" >> /var/log/bootstrap.log
        """.base64
    tags = new {
        new { key = "Name"; value = vars.projectName }
        new { key = "Project"; value = vars.projectName }
        new { key = "ManagedBy"; value = "formae" }
    }
}

local elasticIp = new eip.EIP {
    label = "vm-eip"
    domain = "vpc"
    tags = new {
        new { key = "Name"; value = "\(vars.projectName)-eip" }
        new { key = "Project"; value = vars.projectName }
    }
}

local eipAssociation = new eipassoc.EIPAssociation {
    label = "vm-eip-assoc"
    instanceId = instance.res.instanceId
    allocationId = elasticIp.res.allocationId
}

forma {
    vars.stack
    vars.target

    securityGroup
    sshIngress
    httpIngress
    httpsIngress

    instance
    elasticIp
    eipAssociation
}
